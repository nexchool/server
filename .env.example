# =============================================================================
# Local Flask without Docker
# =============================================================================
# If you use **school-erp-infra** + `make dev`, configure the API in:
#   school-erp-infra/env/.env.local
# (Compose passes that file into the `api` container — you do not need server/.env.)
#
# Copy this file only when running the backend directly on your machine, e.g.:
#   cp .env.example .env
# Then edit `.env` (`.env` is gitignored — never commit it).
# =============================================================================

FLASK_APP=backend.app:create_app
FLASK_ENV=development

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=school_erp
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
RESET_TOKEN_EXP_MINUTES=30

DEFAULT_TENANT_SUBDOMAIN=default

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
DEFAULT_SENDER_NAME=

BACKEND_URL_DEV=http://127.0.0.1:5001
FRONTEND_URL_DEV=
LOCAL_IP=
EXPO_PORT=8081

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
SESSION_COOKIE_SAMESITE=Lax
