# Local development API — bind-mount ./app to /app; dependencies in /venv (not overwritten).
# Usage: docker-compose.local.yml (docker-compose.dev.yml includes it)

FROM python:3.14-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    FLASK_APP=app:create_app \
    PYTHONPATH=/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpango-1.0-0 \
    libharfbuzz0b \
    libpangoft2-1.0-0 \
    libharfbuzz-subset0 \
    libcairo2 \
    libgdk-pixbuf-2.0-0 \
    libffi8 \
    libjpeg62-turbo \
    libopenjp2-7 \
    build-essential \
    libffi-dev \
    libjpeg-dev \
    libopenjp2-7-dev \
    fonts-dejavu-core \
    shared-mime-info \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/requirements.txt
RUN python -m venv /venv && \
    /venv/bin/pip install --upgrade pip && \
    /venv/bin/pip install --no-cache-dir -r /tmp/requirements.txt

ENV PATH="/venv/bin:$PATH"

WORKDIR /app

EXPOSE 5001

# Expect source mounted at /app (see docker-compose.local.yml)
CMD ["sh", "-c", "chmod +x ./startup.sh && ./startup.sh"]